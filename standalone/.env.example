UPS2MQTT_MQTT_HOST=
UPS2MQTT_MQTT_PORT=1883
UPS2MQTT_MQTT_USERNAME=
UPS2MQTT_MQTT_PASSWORD=
UPS2MQTT_LOG_LEVEL=INFO
UPS_AUDIT_SYSLOG_ENABLED=false
UPS_AUDIT_SYSLOG_HOST=127.0.0.1
UPS_AUDIT_SYSLOG_PORT=514

# Optional Caddy reverse proxy (public entrypoint)
UPS2MQTT_PROXY_HOSTNAME=ups2mqtt.local
UPS2MQTT_PROXY_HTTP_PORT=8080
UPS2MQTT_PROXY_HTTPS_PORT=8443
UPS2MQTT_PROXY_USERNAME=admin
# Example hash for password: changeme (replace in real deployments)
UPS2MQTT_PROXY_PASSWORD_HASH=$$2a$$14$$x784qDqIEqHfNoZu6tZvhOwGlnKjPv2QyWPTcuPgdF/O/Fumtk/ma

# Optional direct app bind for local/dev access
UPS2MQTT_WEB_BIND=127.0.0.1
UPS2MQTT_WEB_PORT=8099
