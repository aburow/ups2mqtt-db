UPS2MQTT_MQTT_HOST=
UPS2MQTT_MQTT_PORT=1883
UPS2MQTT_MQTT_USERNAME=
UPS2MQTT_MQTT_PASSWORD=
UPS2MQTT_LOG_LEVEL=INFO
UPS_AUDIT_SYSLOG_ENABLED=false
UPS_AUDIT_SYSLOG_HOST=127.0.0.1
UPS_AUDIT_SYSLOG_PORT=514

# Optional Caddy reverse proxy (public entrypoint)
UPS2MQTT_PROXY_HOSTNAME=ups2mqtt.local
UPS2MQTT_PROXY_HTTP_PORT=8080
UPS2MQTT_PROXY_HTTPS_PORT=8443
UPS2MQTT_PROXY_USERNAME=admin
# Example hash for password: changeme (replace in real deployments)
UPS2MQTT_PROXY_PASSWORD_HASH=$$2a$$14$$x784qDqIEqHfNoZu6tZvhOwGlnKjPv2QyWPTcuPgdF/O/Fumtk/ma

# Optional direct app bind for local/dev access
UPS2MQTT_WEB_BIND=127.0.0.1
UPS2MQTT_WEB_PORT=8099

# Optional InfluxDB v3 telemetry export (disabled by default)
UPS2MQTT_TELEMETRY_INFLUX_ENABLED=false
UPS2MQTT_TELEMETRY_INFLUX_URL=http://influxdb.example.local:8181
UPS2MQTT_TELEMETRY_INFLUX_API=v3
UPS2MQTT_TELEMETRY_INFLUX_DATABASE=ups2mqtt_test
UPS2MQTT_TELEMETRY_INFLUX_TOKEN=replace_with_influxdb_v3_token
UPS2MQTT_TELEMETRY_INFLUX_MEASUREMENT=ups2mqtt
UPS2MQTT_TELEMETRY_INFLUX_TIMEOUT_SECONDS=2.0
UPS2MQTT_TELEMETRY_INFLUX_QUEUE_SIZE=1000
UPS2MQTT_TELEMETRY_INFLUX_FLUSH_INTERVAL_SECONDS=5.0
UPS2MQTT_TELEMETRY_INFLUX_BATCH_MAX_POINTS=500
UPS2MQTT_TELEMETRY_INFLUX_ACCEPT_PARTIAL=true
