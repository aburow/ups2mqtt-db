#
# Copy to .env.pre-release and fill with your local test values.
# This file contains non-secret examples only.
#

# Proxmox API
PROXMOX_API_URL=https://proxmox.example.com:8006/api2/json
PROXMOX_TOKEN_ID=ups2mqtt@pam!ups2mqtt
PROXMOX_TOKEN_SECRET=replace_me
PROXMOX_NODE=pve1
PROXMOX_VM_ID=replace_me
PROXMOX_TLS_INSECURE=false

# HAOS SSH access
HAOS_HOST=haos.example.local
HAOS_SSH_USER=root
HAOS_SSH_PORT=22
HAOS_SSH_KEY_PATH=/path/to/haos_key

# Optional: override SSH client command used by pre-release targets
# PRE_RELEASE_SSH_CMD='ssh -F /dev/null'

# Optional: add-on runtime validation command used by make pre-release-run.
# When unset, pre-release-run remains smoke-only.
# PRE_RELEASE_TEST_CMD='./scripts/pre-release-haos-addon-test.sh'

# Optional tuning values (must be positive integers when set)
# PROXMOX_API_TIMEOUT=20
# HAOS_SSH_TIMEOUT=15
# PRE_RELEASE_SNAPSHOT_VERIFY_RETRIES=10
# PRE_RELEASE_SNAPSHOT_VERIFY_DELAY=2
# PRE_RELEASE_ROLLBACK_VERIFY_RETRIES=30
# PRE_RELEASE_ROLLBACK_VERIFY_DELAY=5
# PRE_RELEASE_HAOS_READY_RETRIES=30
# PRE_RELEASE_HAOS_READY_DELAY=5

# Optional runtime-validation script inputs
# PRE_RELEASE_ADDON_REPOSITORY_URL=https://github.com/aburow/ups2mqtt-db
# PRE_RELEASE_ADDON_SLUG=ups2mqtt
# PRE_RELEASE_ADDON_OPTIONS_JSON='{"mqtt_enabled":true,"mqtt_host":"core-mosquitto","mqtt_port":1883,"config":"devices: []\n"}'
# PRE_RELEASE_MQTT_USERNAME=ups2mqtt_pre_release
# PRE_RELEASE_MQTT_PASSWORD=replace_me
# PRE_RELEASE_TEST_DEVICE_ID=test-ups
# PRE_RELEASE_TEST_DEVICE_HOST=192.0.2.10
# PRE_RELEASE_TEST_DEVICE_SOURCE=apc_modbus_smart
# PRE_RELEASE_TEST_DEVICE_SNMP_COMMUNITY=public
# PRE_RELEASE_LOG_TAIL_LINES=200
# PRE_RELEASE_LOG_VERIFY_RETRIES=20
# PRE_RELEASE_LOG_VERIFY_DELAY=3
# PRE_RELEASE_RESTART_VERIFY_RETRIES=20
# PRE_RELEASE_RESTART_VERIFY_DELAY=3
